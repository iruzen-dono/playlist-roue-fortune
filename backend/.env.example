PORT=3001
NODE_ENV=development

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3001/api/spotify/callback

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# LLM (Cloudflare Workers AI recommandé)
LLM_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CF_LLM_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# LLM fallback OpenAI-compatible (Groq, etc.)
# LLM_PROVIDER=openai
# LLM_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
# LLM_API_KEY=
# LLM_MODEL=llama-3.3-70b-versatile

# Session
SESSION_SECRET=change-me-in-production
HOST_PASSWORD=admin123

# CORS (production — liste d'origines séparées par des virgules)
# CORS_ORIGIN=https://the-chosen-1ne-1.taile64e86.ts.net
